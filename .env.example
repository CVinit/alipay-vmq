# ============================================================
# Shared PostgreSQL
# ============================================================
TZ=Asia/Shanghai
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERPASS=changeme_super_password

# VMQ database
VMQ_DB_NAME=vmq
VMQ_DB_USER=vmq
VMQ_DB_PASSWORD=changeme_vmq_password

# Dujiao-Next database
DUJIAO_DB_NAME=dujiao
DUJIAO_DB_USER=dujiao
DUJIAO_DB_PASSWORD=changeme_dujiao_password

# Alipay-VMQ database
ALIPAY_VMQ_DB_NAME=alipay_vmq
ALIPAY_VMQ_DB_USER=alipay_vmq
ALIPAY_VMQ_DB_PASSWORD=changeme_alipay_vmq_password

# ============================================================
# Alipay-VMQ 中间件配置
# ============================================================

# Alipay (支付宝开放平台)
ALIPAY_APP_ID=your_app_id
ALIPAY_PRIVATE_KEY=your_rsa2_private_key_content
# Or use file path instead:
# ALIPAY_PRIVATE_KEY_PATH=/path/to/private_key.pem
ALIPAY_PUBLIC_KEY=alipay_rsa2_public_key_content
# Set to true to use Alipay sandbox gateway (default: false = production)
ALIPAY_SANDBOX=false

# VMQ
VMQ_BASE_URL=http://vmq:8080
VMQ_KEY=your_vmq_merchant_key
VMQ_DEVICE_KEY=your_vmq_device_key

# Epay
EPAY_MERCHANT_ID=1000
EPAY_MERCHANT_KEY=your_epay_merchant_key_at_least_32_chars

# Database
DATABASE_DRIVER=postgres
DATABASE_URL=postgres://alipay_vmq:changeme_alipay_vmq_password@shared-postgres:5432/alipay_vmq?sslmode=disable

# Service
PUBLIC_BASE_URL=https://pay.example.com
LISTEN_ADDR=:8081
VMQ_ORDER_TIMEOUT=5
POLL_INTERVAL=30
