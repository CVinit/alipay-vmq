# Override example: connect to existing VMQ Docker network and shared PostgreSQL
# Usage: docker compose -f docker-compose.yml -f docker-compose.override.yml up -d

services:
  alipay-vmq:
    environment:
      - DATABASE_DRIVER=postgres
      - DATABASE_URL=postgres://alipay_vmq:changeme@postgres:5432/alipay_vmq?sslmode=disable
      - VMQ_BASE_URL=http://vmq:8080
    networks:
      - vmq_default

networks:
  vmq_default:
    external: true
    name: vmq-go_default  # adjust to match your VMQ compose project network name
